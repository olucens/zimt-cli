FROM node:22-alpine AS builder

WORKDIR /usr/src/app

RUN apk add --no-cache openssl

COPY package*.json ./
<% if (packageManager === 'yarn') { %>COPY yarn.lock ./<% } else if (packageManager === 'pnpm') { %>COPY pnpm-lock.yaml ./<% } else if (packageManager === 'bun') { %>COPY bun.lockb ./<% } else { %>COPY package-lock.json* ./<% } %>
COPY prisma ./prisma/

<% if (packageManager === 'yarn') { %>RUN yarn install --frozen-lockfile<% } else if (packageManager === 'pnpm') { %>RUN corepack enable pnpm && pnpm install --frozen-lockfile<% } else if (packageManager === 'bun') { %>RUN npm install -g bun && bun install --frozen-lockfile<% } else { %>RUN npm ci<% } %>

COPY . .

RUN <% if (packageManager === 'yarn') { %>yarn<% } else if (packageManager === 'pnpm') { %>pnpm exec<% } else if (packageManager === 'bun') { %>bunx<% } else { %>npx<% } %> prisma generate
RUN <% if (packageManager === 'yarn') { %>yarn build<% } else if (packageManager === 'pnpm') { %>pnpm run build<% } else if (packageManager === 'bun') { %>bun run build<% } else { %>npm run build<% } %>

FROM node:22-alpine

WORKDIR /usr/src/app

RUN apk add --no-cache openssl

COPY package*.json ./
RUN <% if (packageManager === 'yarn') { %>yarn install --production --frozen-lockfile<% } else if (packageManager === 'pnpm') { %>corepack enable pnpm && pnpm install --prod --frozen-lockfile<% } else if (packageManager === 'bun') { %>npm install -g bun && bun install --production<% } else { %>npm ci --only=production<% } %>

COPY --from=builder /usr/src/app/dist ./dist
COPY --from=builder /usr/src/app/prisma ./prisma
COPY --from=builder /usr/src/app/node_modules/@prisma ./node_modules/@prisma
COPY --from=builder /usr/src/app/node_modules/.prisma ./node_modules/.prisma

ENV PORT=4000
EXPOSE ${PORT}

CMD ["node", "dist/main"]
